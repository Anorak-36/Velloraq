# Velloraq local workstation profile.
# Copy to .env when running on your laptop with Docker Compose or a local PostgreSQL server.

# App environment
VELLORAQ_APP_NAME=Velloraq
VELLORAQ_APP_ENV=development
VELLORAQ_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Database
POSTGRES_USER=velloraq
POSTGRES_PASSWORD=change-me-local-postgres
POSTGRES_DB=velloraq
VELLORAQ_DATABASE_URL=postgresql+pg8000://velloraq:change-me-local-postgres@velloraq-db:5432/velloraq

# JWT/security
VELLORAQ_JWT_SECRET_KEY=change-me-generate-with-python-secrets-token-urlsafe
VELLORAQ_JWT_ALGORITHM=HS256
VELLORAQ_ACCESS_TOKEN_EXPIRE_MINUTES=60
VELLORAQ_PASSWORD_BCRYPT_ROUNDS=12
VELLORAQ_RATE_LIMIT_REQUESTS=120
VELLORAQ_RATE_LIMIT_WINDOW_SECONDS=60

# Admin bootstrap
VELLORAQ_FIRST_ADMIN_EMAIL=admin@example.local
VELLORAQ_FIRST_ADMIN_PASSWORD=change-me-admin-password-min-12

# Registration settings
VELLORAQ_OPEN_REGISTRATION=true

# Report settings
VELLORAQ_ALLOWED_SOURCE_ROOTS=.
VELLORAQ_REPORTS_DIR=reports

# Worker settings
VELLORAQ_SCAN_POLL_INTERVAL_SECONDS=5
VELLORAQ_SCAN_WORKER_BATCH_SIZE=1
VELLORAQ_ENABLE_WEBHOOKS=false
VELLORAQ_WEBHOOK_TIMEOUT_SECONDS=10

# Optional cloud provider settings
# AWS_PROFILE=velloraq-readonly
# AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
# AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
# AZURE_CLIENT_SECRET=change-me-use-a-secret-manager-or-runtime-env
# GOOGLE_APPLICATION_CREDENTIALS=/secure/path/velloraq-readonly.json
# NVD_API_KEY=change-me-optional-nvd-key
