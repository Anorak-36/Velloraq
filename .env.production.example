# Velloraq production profile.
# Copy to .env on the host and replace all change-this/change-me values before first boot.
# The app refuses to start in production when the JWT secret still looks like a placeholder.

# App environment
VELLORAQ_APP_NAME=Velloraq
VELLORAQ_APP_ENV=production
VELLORAQ_ALLOWED_ORIGINS=https://velloraq.example.com

# Database
POSTGRES_USER=velloraq
POSTGRES_PASSWORD=change-this-to-a-long-random-postgres-password
POSTGRES_DB=velloraq
VELLORAQ_DATABASE_URL=postgresql+pg8000://velloraq:change-this-to-a-long-random-postgres-password@velloraq-db:5432/velloraq

# JWT/security
VELLORAQ_JWT_SECRET_KEY=change-this-to-a-long-random-secret
VELLORAQ_JWT_ALGORITHM=HS256
VELLORAQ_ACCESS_TOKEN_EXPIRE_MINUTES=60
VELLORAQ_PASSWORD_BCRYPT_ROUNDS=12
VELLORAQ_RATE_LIMIT_REQUESTS=120
VELLORAQ_RATE_LIMIT_WINDOW_SECONDS=60

# Admin bootstrap
VELLORAQ_FIRST_ADMIN_EMAIL=admin@example.com
VELLORAQ_FIRST_ADMIN_PASSWORD=change-this-to-a-long-random-admin-password

# Registration settings
VELLORAQ_OPEN_REGISTRATION=false

# Report settings
VELLORAQ_ALLOWED_SOURCE_ROOTS=/workspace,/app/examples
VELLORAQ_REPORTS_DIR=/app/reports

# Worker settings
VELLORAQ_SCAN_POLL_INTERVAL_SECONDS=5
VELLORAQ_SCAN_WORKER_BATCH_SIZE=1
VELLORAQ_ENABLE_WEBHOOKS=false
VELLORAQ_WEBHOOK_TIMEOUT_SECONDS=10

# Optional cloud provider settings
# AWS_PROFILE=velloraq-readonly
# AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
# AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
# AZURE_CLIENT_SECRET=change-me-in-runtime-secret-store
# GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcp-readonly.json
# NVD_API_KEY=change-me-optional-nvd-key
# HTTPS_PROXY=http://proxy.example.com:8080
# HTTP_PROXY=http://proxy.example.com:8080
# NO_PROXY=localhost,127.0.0.1,velloraq-db
